{
  "name": "hermesos-desktop",
  "version": "0.1.0-alpha",
  "description": "HermesOS desktop client",
  "author": "essencocean-oss",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.essencocean.hermesos",
    "productName": "HermesOS",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}